{
  "name": "biblian",
  "version": "1.0.1",
  "description": "Faroese Bible verse display application for churches and presentations",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build:wasm": "cd search-wasm && wasm-pack build --target nodejs --out-dir ../src/search-pkg",
    "build:data": "node -e \"const fs=require('fs');const d=JSON.parse(fs.readFileSync('src/data/bible.json','utf-8'));fs.writeFileSync('src/data/bible.json',JSON.stringify(d));\"",
    "build:index": "node scripts/build-bible-index.js",
    "dev": "npm run build:data && npm run build:index && npm run build:wasm && electron .",
    "dist": "electron-builder",
    "dist:all": "electron-builder -mwl",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "repository": {
    "type": "git",
    "url": "http://local_proxy@127.0.0.1:22782/git/jhoj/Biblian"
  },
  "keywords": [
    "bible",
    "faroese",
    "presentation",
    "church"
  ],
  "author": "Jákup Høj <jakup@hoj.fo>",
  "license": "ISC",
  "dependencies": {
    "electron": "^33.0.0",
    "electron-updater": "^6.7.3"
  },
  "devDependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "@resvg/resvg-js": "^2.6.2",
    "electron-builder": "^26.7.0"
  },
  "build": {
    "appId": "fo.hoj.biblian",
    "productName": "Biblían",
    "files": [
      "src/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icons"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "publish": {
      "provider": "github",
      "owner": "jhoj",
      "repo": "Biblian"
    }
  }
}
